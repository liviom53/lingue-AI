modules = ["nodejs-24"]

  [[artifacts]]
  id = "artifacts/diario-pescatore"

  [[ports]]
  localPort = 8080
  externalPort = 80

  [deployment]
  router = "application"
  deploymentTarget = "vm"

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  