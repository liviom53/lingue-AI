modules = ["nodejs-24"]

  [[ports]]
  localPort = 8080
  externalPort = 80

  [deployment]
  run = ["node", "--enable-source-maps", "artifacts/api-server/dist/index.mjs"]
  build = ["sh", "-c", "NODE_ENV=production BASE_PATH=/lingua-ai/ pnpm --filter @workspace/lingua-ai run build && NODE_ENV=production BASE_PATH=/ pnpm --filter @workspace/diario-pescatore run build && NODE_ENV=production pnpm --filter @workspace/api-server run build"]
  deploymentTarget = "autoscale"

  [deployment.env]
  NODE_ENV = "production"

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  